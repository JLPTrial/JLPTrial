{
  "packages": [
    "nodejs@22",
    "pnpm",
    "git",
    "python3",
    "pkg-config",
    "gcc",
    "gnumake",
    "openjdk@17", 
    "watchman",
    "unzip",
    "android-tools"
  ],
  "shell": {
    "init_hook": [
      ". $VENV_DIR/bin/activate"
    ],
    "scripts": {
      "test": "${DEVBOX_PROJECT_ROOT}/scripts/test.sh \"$@\"",
      "lint": "${DEVBOX_PROJECT_ROOT}/scripts/lint.sh \"$@\"",
      "setup": "${DEVBOX_PROJECT_ROOT}/scripts/setup.sh \"$@\"",
      "startBackend": "${DEVBOX_PROJECT_ROOT}/scripts/server/startBackend.sh",
      "startWeb": "${DEVBOX_PROJECT_ROOT}/scripts/web/startWeb.sh",
      "startDev": "${DEVBOX_PROJECT_ROOT}/scripts/web/startDev.sh",
      "startAndroid": "${DEVBOX_PROJECT_ROOT}/scripts/app/runMobile.sh android debug",
      "buildAndroid": "${DEVBOX_PROJECT_ROOT}/scripts/app/runMobile.sh android release",
      "clean": "bash ${DEVBOX_PROJECT_ROOT}/scripts/clean.sh \"$@\""
    }
  },
  "env_from": ".env",
  "env": {
    "NODE_ENV": "development",
    "ANDROID_HOME": "$HOME/Android/Sdk",
    "npm_config_legacy_peer_deps": "true"
  }
}