## Flavor ativo: dev ou prod
# BACKEND (SERVER)
APP_FLAVOR=dev

## =========================
## Autenticação
## =========================

# FRONTEND (WEB)

VITE_DEV_API_URL="http://localhost:8000/"
VITE_PROD_API_URL=""

VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""

#BACKEND
FIREBASE_SERVICE_ACCOUNT_FILE=""
FIREBASE_SESSION_COOKIE_EXPIRE_DAYS=10

## =========================
## Desenvolvimento (dev)
## =========================
DEV_BACKEND_HOST=localhost
DEV_BACKEND_PORT=8000

DEV_WEB_HOST=0.0.0.0
DEV_WEB_PORT=5173

## Endereço base da API acessível por mobile (emulador/dispositivo).
## Troque para seu IP local quando testar em dispositivo real.
DEV_MOBILE_API_HOST=127.0.0.1
DEV_MOBILE_API_PORT=8000

## Endereço base que a API dará permissão de acesso
DEV_BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
## =========================
## Produção (prod)
## =========================
PROD_BACKEND_HOST=""
PROD_BACKEND_PORT=""

PROD_WEB_HOST=""
PROD_WEB_PORT=""

## Host da API pública para apps mobile em produção.
PROD_MOBILE_API_HOST=""
PROD_MOBILE_API_PORT=""

## Origens de CORS do backend (separadas por vírgula)
PROD_BACKEND_CORS_ORIGINS=""

## =========================
## Flags de execução
## =========================

# Marque como False para testar as chamadas de API sem validação Firebase
SECURE_REQUEST=False